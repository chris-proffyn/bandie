# Environment variables — copy to `.env` at repo root
# Web app: copy VITE_* vars to `apps/web/.env.local`
# Supabase CLI: copy server vars to `supabase/.env`

# --- Client (Vite / Expo — publishable key only) ---
VITE_SUPABASE_URL=https://cjmgrsvbrcgozgjxbriz.supabase.co
# Publishable key (sb_publishable_...) — replaces legacy anon key
VITE_SUPABASE_ANON_KEY=
VITE_APP_CODE=bandie
VITE_APP_URL=http://localhost:5173
# Data mode: `live` hides fictitious test bands/players; `test` shows everything
VITE_BANDIE_DATA_MODE=test

# --- Server / CLI only (never VITE_ prefix, never in client bundles) ---
SUPABASE_URL=https://cjmgrsvbrcgozgjxbriz.supabase.co
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# Dropbox song-part storage (Netlify Functions — server-side only)
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=
# 32-byte encryption key as 64-character hex string for OAuth tokens
BANDIE_INTEGRATION_TOKEN_KEY=
