{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "@bandie/utils": ["../utils/src"],
      "@bandie/utils/*": ["../utils/src/*"]
    }
  },
  "include": ["src"]
}
